{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "composite": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "tailwind.config.ts",
    "postcss.config.cjs",
    "components.json",
    "tailwindcss-animate.d.ts"
  ]
}
